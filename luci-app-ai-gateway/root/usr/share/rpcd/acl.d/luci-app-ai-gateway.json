{
	"luci-app-ai-gateway": {
		"description": "Grant access to AI Gateway configuration",
		"read": {
			"ubus": {
				"service": ["list"],
				"uci": ["ai-gateway"],
				"luci": ["getInitList"]
			},
			"uci": ["ai-gateway"],
			"file": {
				"/etc/ai-gateway/ca/ca.crt": ["read"],
				"/tmp/ai-gateway/*": ["read"],
				"/usr/bin/logread": ["exec"]
			}
		},
		"write": {
			"ubus": {
				"uci": ["ai-gateway"]
			},
			"uci": ["ai-gateway"],
			"file": {
				"/etc/ai-gateway/ca/*": ["write"],
				"/tmp/ai-gateway/*": ["write"]
			}
		}
	}
}
