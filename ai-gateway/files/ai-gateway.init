#!/bin/sh /etc/rc.common

USE_PROCD=1
START=99
STOP=10

CONF="ai-gateway"
PROG="/usr/bin/ai-gateway"
DNSMASQ_DIR="/tmp/dnsmasq.d/ai-gateway"

start_service() {
	config_load "$CONF"

	local enabled
	config_get enabled global enabled "0"
	[ "$enabled" = "1" ] || return 0

	# Ensure CA directory exists
	local ca_dir
	config_get ca_dir global ca_dir "/etc/ai-gateway/ca"
	mkdir -p "$ca_dir"

	# Ensure cert cache directory exists
	local cert_cache_dir
	config_get cert_cache_dir global cert_cache_dir "/tmp/ai-gateway/certs"
	mkdir -p "$cert_cache_dir"

	# Setup DNS hijacking for all enabled provider domains
	setup_dns_hijack

	# Start the daemon
	procd_open_instance "ai-gateway"
	procd_set_param command "$PROG" -uci
	procd_set_param respawn
	procd_set_param limits nofile="65535 65535"
	procd_set_param stderr 1
	procd_set_param stdout 1
	procd_close_instance

	logger -t ai-gateway "Service started"
}

stop_service() {
	# Clean up DNS hijacking
	cleanup_dns_hijack
	logger -t ai-gateway "Service stopped"
}

reload_service() {
	stop
	start
}

service_triggers() {
	procd_add_reload_trigger "$CONF"
}

# Get the router's LAN IP address for DNS hijacking
get_lan_ip() {
	local lan_ip
	lan_ip=$(uci -q get network.lan.ipaddr)
	if [ -z "$lan_ip" ]; then
		lan_ip=$(ip -4 addr show br-lan 2>/dev/null | grep -oP 'inet \K[\d.]+' | head -1)
	fi
	if [ -z "$lan_ip" ]; then
		lan_ip="192.168.1.1"
	fi
	echo "$lan_ip"
}

# Setup dnsmasq DNS hijacking for AI API domains
setup_dns_hijack() {
	local lan_ip
	lan_ip=$(get_lan_ip)

	mkdir -p "$DNSMASQ_DIR"

	# Generate DNS hijack rules for each enabled provider
	local providers="anthropic openai gemini"
	local conf_file="$DNSMASQ_DIR/ai-gateway.conf"

	echo "# AI Gateway DNS hijack - auto-generated, do not edit" > "$conf_file"
	echo "# Generated at: $(date)" >> "$conf_file"

	for provider in $providers; do
		local enabled
		enabled=$(uci -q get ai-gateway.$provider.enabled)
		[ "$enabled" = "1" ] || continue

		local domains
		domains=$(uci -q get ai-gateway.$provider.domains)
		if [ -z "$domains" ]; then
			case "$provider" in
				anthropic) domains="api.anthropic.com" ;;
				openai) domains="api.openai.com" ;;
				gemini) domains="generativelanguage.googleapis.com" ;;
			esac
		fi

		for domain in $domains; do
			echo "address=/$domain/$lan_ip" >> "$conf_file"
			logger -t ai-gateway "DNS hijack: $domain → $lan_ip"
		done
	done

	# Reload dnsmasq to pick up new config
	if [ -f "$conf_file" ] && [ -s "$conf_file" ]; then
		/etc/init.d/dnsmasq restart 2>/dev/null
		logger -t ai-gateway "dnsmasq reloaded with AI domain hijacking"
	fi
}

# Remove DNS hijacking configuration
cleanup_dns_hijack() {
	if [ -d "$DNSMASQ_DIR" ]; then
		rm -rf "$DNSMASQ_DIR"
		/etc/init.d/dnsmasq restart 2>/dev/null
		logger -t ai-gateway "DNS hijack rules removed, dnsmasq reloaded"
	fi
}
